# .env.example

# Telegram Bot Token
BOT_TOKEN=your-telegram-bot-token

# Admin user ID for daily stats (optional)
ADMIN_ID=

# Database configuration
DB_DRIVER=pdo_sqlite      # pdo_sqlite | pdo_mysql | pdo_pgsql
DB_HOST=127.0.0.1         # ignored for SQLite
DB_PORT=                  # 3306 (MySQL), 5432 (PostgreSQL), ignored for SQLite
DB_NAME=machinimators     # ignored for SQLite
DB_USER=root              # ignored for SQLite
DB_PASSWORD=              # ignored for SQLite
DB_PATH=machinimators.db  # SQLite only
