{
    "name": "morfeditorial/machinima-bot",
    "repositories": [
        {
            "type": "path",
            "url": "../telegram-bot-bundle"
        }
    ],
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.2",
        "symfony/http-kernel": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/workflow": "^8.1",
        "morfeditorial/telegram-bot-bundle": "*@dev"
    },
    "autoload": {
        "psr-4": {
            "Morfeditorial\\": "src/"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
