{
    "name": "morfeditorial/machinima-bot",
    "description": "The official Telegram Bot for the Machinima platform.",
    "type": "symfony-bundle",
    "license": "LicenseRef-CSSM-Unlimited-2.0",
    "authors": [
        {
            "name": "Serhii Cherneha",
            "email": "chernegasergiy3@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/http-kernel": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "morfeditorial/machinima-core": "dev-main",
        "morfeditorial/telegram-bot-bundle": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Morfeditorial\\": "src/"
        }
    },
